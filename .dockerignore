# Secrets - never bake these into the image; Cloud Run injects them as env vars/secrets instead
.env
.env.*

# Version control / editor / OS cruft
.git
.gitignore
.claude/
.vscode/
.idea/
.DS_Store
Thumbs.db

# Python
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
.venv
venv/
ENV/
env/
*.egg-info/

# Tests and docs - not needed in the runtime image
app/tests/
*.md
skills-lock.json
