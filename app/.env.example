DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# FPT Cloud Marketplace chat-completions API — leave FPT_CLOUD_API_KEY unset
# to run without the chatbot; /assistant/health will report configured=false
# and /assistant/chat will return 503 instead of crashing the app.
FPT_CLOUD_API_KEY=""
