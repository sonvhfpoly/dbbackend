DATABASE_URL=""

# FPT Cloud Marketplace chat-completions API — leave FPT_CLOUD_API_KEY unset
# to run without the chatbot; /assistant/health will report configured=false
# and /assistant/chat will return 503 instead of crashing the app.
FPT_CLOUD_API_KEY=""
# FPT_CLOUD_BASE_URL="https://mkp-api.fptcloud.com"
FPT_CLOUD_CHAT_MODEL="gemma-4-31B-it"

# Vertex AI (Gemini) — preferred provider when available. On Cloud Run with a
# service account attached, Application Default Credentials load
# automatically at deploy time and no key is needed here at all; leave
# VERTEX_PROJECT_ID unset to auto-detect the project from ADC. Locally, run
# `gcloud auth application-default login` to pick this provider up instead of
# falling back to FPT Cloud above.
# VERTEX_PROJECT_ID="your-gcp-project-id"
# VERTEX_LOCATION="asia-southeast1"
# VERTEX_MODEL="gemini-2.5-flash"
